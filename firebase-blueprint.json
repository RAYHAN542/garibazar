{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account and wallet balance tracking doc",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "city": { "type": "string" },
        "profilePicture": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string" },
        "simulatedCredits": { "type": "number" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" }
      },
      "required": ["uid", "displayName", "phoneNumber", "createdAt"]
    },
    "Listing": {
      "title": "Spare Part Listing",
      "description": "Details about a spare part listing posted for sale",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "model": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "contactNumber": { "type": "string" },
        "sellerName": { "type": "string" },
        "sellerPhoto": { "type": "string" },
        "location": { "type": "string" },
        "image": { "type": "string" },
        "images": { "type": "array" },
        "hasVideo": { "type": "boolean" },
        "views": { "type": "number" },
        "clicks": { "type": "number" },
        "isAd": { "type": "boolean" },
        "adTier": { "type": "string" },
        "createdAt": { "type": "string" },
        "sellerId": { "type": "string" },
        "isSold": { "type": "boolean" },
        "reportCount": { "type": "number" },
        "reportedBy": { "type": "array" }
      },
      "required": ["title", "category", "model", "price", "description", "contactNumber", "sellerName", "location", "image", "createdAt", "sellerId"]
    },
    "RefillRequest": {
      "title": "Wallet Refill Request",
      "description": "Ad credit refill and upgrade token request details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "senderNumber": { "type": "string" },
        "txId": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" },
        "approvedAt": { "type": "string" },
        "rejectedAt": { "type": "string" }
      },
      "required": ["userId", "amount", "method", "status", "createdAt"]
    },
    "Purchase": {
      "title": "Purchase Order",
      "description": "Records purchase order detail history from dashboard actions",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "image": { "type": "string" },
        "price": { "type": "number" },
        "sellerName": { "type": "string" },
        "sellerContact": { "type": "string" },
        "buyerId": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "price", "buyerId", "status", "createdAt"]
    },
    "Review": {
      "title": "Seller Review",
      "description": "Star ratings and written feedback left for part sellers",
      "type": "object",
      "properties": {
        "sellerId": { "type": "string" },
        "reviewerId": { "type": "string" },
        "reviewerName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["sellerId", "reviewerId", "reviewerName", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user accounts"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Collection of spare parts details"
    },
    "/refill_requests/{requestId}": {
      "schema": "RefillRequest",
      "description": "Refill credits transactions requests"
    },
    "/purchases/{purchaseId}": {
      "schema": "Purchase",
      "description": "Purchase order actions tracking history"
    },
    "/seller_reviews/{reviewId}": {
      "schema": "Review",
      "description": "STAR feedback and review comments given to sellers"
    }
  }
}
