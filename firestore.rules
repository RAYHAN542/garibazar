rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ---------- USERS ----------
    match /users/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && userId == request.auth.uid;

      // Owner can update their own profile, but NOT their own wallet balance.
      // Only admin (via approved refill_requests) can change simulatedCredits.
      allow update: if isSignedIn() && (
                      (userId == request.auth.uid &&
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(['simulatedCredits', 'uid'])
                      ) || isAdmin()
                    );
      allow delete: if isAdmin();
    }

    // ---------- ADMINS ----------
    match /admins/{userId} {
      allow read: if isSignedIn() && userId == request.auth.uid;
      allow write: if false;
    }

    // ---------- LISTINGS ----------
    match /listings/{listingId} {
      allow read: if true;

      allow create: if isSignedIn() &&
                    request.resource.data.sellerId == request.auth.uid &&
                    request.resource.data.price is number &&
                    request.resource.data.price >= 0 &&
                    request.resource.data.price <= 99999999 &&
                    request.resource.data.title is string &&
                    request.resource.data.title.size() > 0 &&
                    request.resource.data.title.size() < 200 &&
                    request.resource.data.description is string &&
                    request.resource.data.description.size() < 3000;

      // Owner can edit their listing but cannot self-promote (isAd/adTier/etc are admin-only).
      allow update: if isSignedIn() && (
                      (resource.data.sellerId == request.auth.uid &&
                       !request.resource.data.diff(resource.data).affectedKeys().hasAny(
                         ['createdAt', 'sellerId', 'isAd', 'adTier', 'adDurationDays', 'adExpiresAt']
                       )
                      ) || isAdmin()
                    );

      // Any signed-in user may bump views by exactly +1 (analytics tracking on view).
      allow update: if isSignedIn() &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) &&
                    request.resource.data.views == (resource.data.views is number ? resource.data.views : 0) + 1;

      // Any signed-in user may bump clicks by exactly +1.
      allow update: if isSignedIn() &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clicks']) &&
                    request.resource.data.clicks == (resource.data.clicks is number ? resource.data.clicks : 0) + 1;

      allow delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    // ---------- REFILL / AD-PROMOTION REQUESTS ----------
    match /refill_requests/{requestId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.amount is number &&
                    request.resource.data.amount > 0;
      allow update, delete: if isAdmin();
    }

    // ---------- PURCHASES (order records, immutable after creation) ----------
    match /purchases/{purchaseId} {
      allow read: if isSignedIn() && (resource.data.buyerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ---------- SELLER REVIEWS ----------
    match /seller_reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() &&
                    request.resource.data.reviewerId == request.auth.uid &&
                    request.resource.data.sellerId is string &&
                    request.resource.data.comment is string &&
                    request.resource.data.comment.size() < 1000 &&
                    request.resource.data.rating is number &&
                    request.resource.data.rating >= 1 &&
                    request.resource.data.rating <= 5;
      allow update, delete: if isSignedIn() && (resource.data.reviewerId == request.auth.uid || isAdmin());
    }

    // ---------- CHATS ----------
    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      allow update: if isSignedIn() &&
                    (request.auth.uid in resource.data.participants) &&
                    !request.resource.data.diff(resource.data).affectedKeys().hasAny(['participants']);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn() &&
                    (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
        allow create: if isSignedIn() &&
                      (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants) &&
                      request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    // ---------- LOTTERY DRAWS (free daily "Boost Ads" lottery, server-only writes) ----------
    // Draws are only ever created by the /api/lottery/draw serverless function (Admin SDK),
    // which bypasses these rules — this keeps the win chance and daily limit tamper-proof.
    match /lottery_draws/{drawId} {
      allow read: if isSignedIn() && (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // ---------- SUPPORT TICKETS (guests can also submit) ----------
    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if (isSignedIn() && request.resource.data.userId == request.auth.uid) ||
                    (!isSignedIn() && request.resource.data.userId == "guest");
      allow update, delete: if isAdmin();
    }

    // ---------- SITE VISIT / LOGIN / SIGNUP ANALYTICS ----------
    // Written only by the /api/track-event serverless function (Admin SDK),
    // which bypasses these rules -- keeps visitor IP/location data from
    // being writable or readable by anyone except an admin.
    match /site_visits/{visitId} {
      allow read: if isAdmin();
      allow write: if false;
    }
    match /analytics_stats/{statId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ---------- Everything else: locked down ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
