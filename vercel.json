{
  "rewrites": [
    { "source": "/l/:id", "destination": "/api/share-listing?id=:id" },
    { "source": "/__/auth/:path*", "destination": "https://garibazar-bd.firebaseapp.com/__/auth/:path*" },
    { "source": "/__/firebase/init.json", "destination": "https://garibazar-bd.firebaseapp.com/__/firebase/init.json" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {"key": "Cache-Control", "value": "public, max-age=31536000, immutable"}
      ]
    },
    {
      "source": "/",
      "headers": [
        {"key": "Cache-Control", "value": "public, max-age=0, must-revalidate"}
      ]
    }
  ]
}
