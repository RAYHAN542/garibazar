# ========================================
# GARI BAZAR — Production Environment Variables
# Vercel এ deploy করার সময় এগুলো Settings > Environment Variables এ add করুন
# ========================================

# --- GEMINI AI ---
# aistudio.google.com/apikey থেকে নিন
GEMINI_API_KEY=your_gemini_api_key_here

# --- FIREBASE CONFIG ---
# Firebase Console > Project Settings > Your Apps থেকে নিন
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:your_app_id
VITE_FIREBASE_FIRESTORE_DATABASE_ID=default
VITE_FIREBASE_MEASUREMENT_ID=G-your_measurement_id

# --- RECAPTCHA ---
# console.cloud.google.com > reCAPTCHA থেকে v3 site key নিন
VITE_RECAPTCHA_SITE_KEY=your_real_recaptcha_v3_site_key

# --- SERVER CONFIG ---
# Production এ আপনার Vercel URL দিন
ALLOWED_ORIGINS=https://garibazar.vercel.app,https://garibazar.com
NODE_ENV=production

# --- ERROR REPORTING (optional) ---
VITE_ENABLE_ERROR_REPORTER=false
VITE_SENTRY_DSN=

# --- APP URL ---
APP_URL=https://garibazar.vercel.app
